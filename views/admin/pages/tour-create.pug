extends ../layouts/default.pug
include ../mixins/checkbox-30.pug
include ../mixins/options.pug

block main
	main.main
		h1.box-title Tạo tour
		.section-8
			form(action="" id="tour-create-form")
				.inner-group 
					label.inner-label(for="name") Tên tour
					input(type="text" id="name" name="name" placeholder="Nhập tên tour")
				.inner-group 
					label.inner-label(for="category") Danh mục 
					select(id="category" name="category")
						option(value="") -- Chọn danh mục --
						+options(categoryList)
				.inner-group 
					label.inner-label(for="position") Vị trí
					input(type="text" id="position" name="position" placeholder="Nhập vị trí hiển thị")
				.inner-group 
					label.inner-label(for="status") Trạng thái
					select(id="status" name="status")
						option(value="active") Hoạt động
						option(value="inactive") Tạm dừng
				.inner-group.inner-two-col
					label.inner-label(for="avatar") Ảnh đại diện
					.inner-upload-image
						input(type="file" id="avatar" name="avatar" filepond-image)        
				.inner-group.inner-two-col
					label.inner-label(for="images") Danh sách ảnh
					div(class="inner-upload-image-multi")
						input(
							type="file" 
							multiple
							id="images" 
							name="images" 
							filepond-image-multi
							data-allow-reorder="true"
							)
				.inner-group 
					label.inner-label Giá cũ
					.inner-list
						.inner-item 
							label.inner-label(for="old-price-adult") Người lớn
							input(type="text" id="old-price-adult" name="priceAdult") 
						.inner-item 
							label.inner-label(for="old-price-child") Trẻ em
							input(type="text" id="old-price-child" name="priceChildren") 
						.inner-item
							label.inner-label(for="old-price-baby") Em bé
							input(type="text" id="old-price-baby" name="priceBaby") 
				.inner-group 
					label.inner-label Giá mới
					.inner-list
						.inner-item 
							label.inner-label(for="new-price-adult") Người lớn
							input(type="text" id="new-price-adult" name="priceNewAdult") 
						.inner-item 
							label.inner-label(for="new-price-child") Trẻ em
							input(type="text" id="new-price-child" name="priceNewChildren") 
						.inner-item
							label.inner-label(for="new-price-baby") Em bé
							input(type="text" id="new-price-baby" name="priceNewBaby") 
				.inner-group 
					label.inner-label Còn lại 
					.inner-list
						.inner-item 
							label.inner-label(for="adult") Người lớn
							input(type="text" id="adult" name="stockAdult") 
						.inner-item 
							label.inner-label(for="child") Trẻ em
							input(type="text" id="child" name="stockChildren") 
						.inner-item
							label.inner-label(for="baby") Em bé
							input(type="text" id="baby" name="stockBaby")
				.inner-group 
					label.inner-label Những địa điểm
					.inner-checkbox
						each item in cityList
							.inner-checkbox-item 
								+checkbox-30("locations", `locations-${item.id}`, item.id)
								label(for=`locations-${item.id}`) #{item.name}
				.inner-group
					label.inner-label(for="departure-date") Ngày khởi hành
					input(type="date" id="departure-date" name="departureDate" placeholder="Nhập ngày khởi hành")
				.inner-group 
					label.inner-label(for="end-date") Ngày kết thúc
					input(type="date" id="end-date" name="endDate" placeholder="Nhập ngày kết thúc")
				.inner-group.inner-two-col
					label.inner-label(for="information") Thông tin tour 
					textarea(id="information" name="information" textarea-mce)
				.inner-group.inner-two-col
					label.inner-label Lịch trình tour
					.inner-schedule
						.inner-schedule-list
							.inner-schedule-item 
								.inner-schedule-head
									.inner-schedule-button.inner-move
										<i class="fa-solid fa-up-down-left-right inner-move"></i>
									input(class="inner-input" type="text")
									.inner-schedule-button.inner-remove
										<i class="fa-solid fa-trash-can"></i>
									.inner-schedule-button.inner-more
										<i class="fa-solid fa-angle-down"></i>
								.inner-schedule-body
									textarea(class="inner-textarea" textarea-mce)
							.inner-schedule-item 
								.inner-schedule-head
									.inner-schedule-button.inner-move
										<i class="fa-solid fa-up-down-left-right inner-move"></i>
									input(class="inner-input" type="text")
									.inner-schedule-button.inner-remove
										<i class="fa-solid fa-trash-can"></i>
									.inner-schedule-button.inner-more
										<i class="fa-solid fa-angle-down"></i>
								.inner-schedule-body
									textarea(class="inner-textarea" textarea-mce)
						.inner-schedule-create + Thêm lịch trình
				.inner-button.inner-two-col
					button Tạo mới
			.inner-back 
				a(href=`/${pathAdmin}/tour/list`) Quay lại danh sách
		