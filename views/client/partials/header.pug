.header
  .container
    .inner-wrap
      button.inner-button-menu
        img(
          alt="Menu Icon" 
          src="/client/assets/image/Icon-menu.png"
          )
      a.inner-logo(href="/")
        img(
          alt=settingWebsiteInfo.websiteName
          src=settingWebsiteInfo.logo
          )
      nav.inner-menu
        ul
          li
            a.active(href="/") Trang Chủ
          each item in categoryList
						li
							a(href=`/category/${item.slug}`) #{item.name}
							if (item.children && item.children.length > 0)
								i.fa-solid.fa-caret-down
							ul.inner-submenu
								each itemChild in item.children
									li
										a(href=`/category/${itemChild.slug}`) #{itemChild.name}
          li
            a(href="#") Tin Tức
          li
            a(href="#") Liên Hệ
        .inner-overlay
      a.inner-cart(href="/cart")
        img(
          alt="Giỏ hàng" 
          src="/client/assets/image/cart.png"
          )
        span.inner-cart-count
          img(
            alt="Giỏ hàng" 
            src="/client/assets/image/left.png"
            )
          div(mini-cart) 0