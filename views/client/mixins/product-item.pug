mixin product-item(item)
  - const discount = Math.floor(((item.priceAdult - item.priceNewAdult)/item.priceAdult)*100);
  .product-item
    .inner-image
      a(href=`/tour/detail/${item.slug}`)
        img(
          alt=item.name
          src=item.avatar
          )
    .inner-discount
      i.fa-solid.fa-bolt
      | Giảm -#{discount}%
    .inner-content
      h3.inner-title
        a(href=`/tour/detail/${item.slug}`) #{item.name}
      .inner-prices
        .inner-price-old
          | #{item.priceAdult.toLocaleString("vi-VN")}
          span.inner-unit đ
        .inner-price-new
          | #{item.priceNewAdult.toLocaleString("vi-VN")}
          span.inner-unit đ
      .inner-desc
        //- div
        //-   | Mã Tour:
        //-   b 123456789
        div
          | Ngày Khởi Hành: 
          b #{item.departureDateFormat}
        div
          | Thời Gian:
          b #{item.time}
      .inner-meta
        .inner-rating
          .inner-stars
            i.fa-solid.fa-star
            i.fa-solid.fa-star
            i.fa-solid.fa-star
            i.fa-solid.fa-star
            i.fa-regular.fa-star
          .inner-number (5)
          .inner-number (5)
        .inner-stock
          .inner-label Số chỗ còn:
          .inner-number #{item.stockAdult}
